{"ast":null,"code":"import{useState,useCallback,useRef}from'react';export function useToast(){const[estado,setEstado]=useState({mensaje:'',visible:false});const temporizador=useRef(null);const mostrar=useCallback(mensaje=>{clearTimeout(temporizador.current);setEstado({mensaje,visible:true});temporizador.current=setTimeout(()=>{setEstado(prev=>({...prev,visible:false}));},3500);},[]);return{toastMensaje:estado.mensaje,toastVisible:estado.visible,mostrarToast:mostrar};}","map":{"version":3,"names":["useState","useCallback","useRef","useToast","estado","setEstado","mensaje","visible","temporizador","mostrar","clearTimeout","current","setTimeout","prev","toastMensaje","toastVisible","mostrarToast"],"sources":["C:/Users/Usuario/Downloads/Proyecto_CDL/frontend/src/componentes/compartidos/useToast.js"],"sourcesContent":["import { useState, useCallback, useRef } from 'react';\n\nexport function useToast() {\n  const [estado, setEstado] = useState({ mensaje: '', visible: false });\n  const temporizador = useRef(null);\n\n  const mostrar = useCallback((mensaje) => {\n    clearTimeout(temporizador.current);\n    setEstado({ mensaje, visible: true });\n    temporizador.current = setTimeout(() => {\n      setEstado((prev) => ({ ...prev, visible: false }));\n    }, 3500);\n  }, []);\n\n  return { toastMensaje: estado.mensaje, toastVisible: estado.visible, mostrarToast: mostrar };\n}\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,WAAW,CAAEC,MAAM,KAAQ,OAAO,CAErD,MAAO,SAAS,CAAAC,QAAQA,CAAA,CAAG,CACzB,KAAM,CAACC,MAAM,CAAEC,SAAS,CAAC,CAAGL,QAAQ,CAAC,CAAEM,OAAO,CAAE,EAAE,CAAEC,OAAO,CAAE,KAAM,CAAC,CAAC,CACrE,KAAM,CAAAC,YAAY,CAAGN,MAAM,CAAC,IAAI,CAAC,CAEjC,KAAM,CAAAO,OAAO,CAAGR,WAAW,CAAEK,OAAO,EAAK,CACvCI,YAAY,CAACF,YAAY,CAACG,OAAO,CAAC,CAClCN,SAAS,CAAC,CAAEC,OAAO,CAAEC,OAAO,CAAE,IAAK,CAAC,CAAC,CACrCC,YAAY,CAACG,OAAO,CAAGC,UAAU,CAAC,IAAM,CACtCP,SAAS,CAAEQ,IAAI,GAAM,CAAE,GAAGA,IAAI,CAAEN,OAAO,CAAE,KAAM,CAAC,CAAC,CAAC,CACpD,CAAC,CAAE,IAAI,CAAC,CACV,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CAAEO,YAAY,CAAEV,MAA